---
interface Props {
  src: string;
  alt: string;
  aspectRatio?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const { src, alt, aspectRatio = '16 / 10', loading = 'lazy', fetchpriority } = Astro.props;
---

<div class="media-card" style={`aspect-ratio: ${aspectRatio}`}>
  <picture>
    <source srcset={src} type="image/webp" />
    <img
      src={src}
      alt={alt}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
    />
  </picture>
</div>

<style>
  .media-card {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform var(--transition), box-shadow var(--transition);
    background: var(--color-section-alt);
  }

  .media-card:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .media-card picture,
  .media-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
