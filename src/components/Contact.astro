<section id="contacto" class="section section-alt">
  <div class="container">
    <div class="contact-header reveal">
      <span class="section-label">Contacto</span>
      <h2 class="section-title">Conversemos.</h2>
      <p class="section-subtitle">En 30 minutos entendemos tu proyecto, identificamos si podemos ayudarte y definimos los siguientes pasos.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-form-wrapper reveal reveal-delay-1">
        <form id="contactForm" action="https://formspree.io/f/mbdbpzlq" method="POST" class="contact-form">
          <div class="form-row">
            <input type="text" name="name" placeholder="Nombre completo" required />
            <input type="email" name="email" placeholder="Correo electrónico" required />
          </div>
          <input type="text" name="company" placeholder="Empresa" required />
          <select name="size" required>
            <option value="">¿Cuántas personas tiene tu equipo?</option>
            <option value="1">Solo yo</option>
            <option value="2-5">2 a 5 personas</option>
            <option value="6-15">6 a 15 personas</option>
            <option value="16+">Más de 15 personas</option>
          </select>
          <textarea name="message" rows="4" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
          <button type="submit" class="btn btn-primary">Enviar mensaje</button>
          <p class="form-note">Respondemos en menos de 24 hrs hábiles.</p>
        </form>
        <div id="formSuccess" class="form-success" hidden>
          <div class="success-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="success-title">¡Gracias!</h3>
          <p class="success-text">Nos pondremos en contacto contigo pronto.</p>
        </div>
      </div>
      <div class="contact-info reveal reveal-delay-2">
        <div class="photo-card contact-photo">
          <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80" alt="Oficina moderna de Accelerazione con equipo trabajando en proyecto digital" loading="lazy" />
        </div>
        <div class="contact-card">
          <div class="contact-item">
            <strong>Email</strong>
            <a href="mailto:hola@accelerazione.com">hola@accelerazione.com</a>
          </div>
          <div class="contact-item">
            <strong>Ubicación</strong>
            <span>Chile & LATAM</span>
          </div>
          <div class="contact-item">
            <strong>LinkedIn</strong>
            <a href="#">linkedin.com/company/accelerazione</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-header {
    margin-bottom: 3rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition);
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--color-text);
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form .btn {
    align-self: flex-start;
  }

  .form-note {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-top: 0.25rem;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .photo-card {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    aspect-ratio: 16 / 10;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .photo-card:hover {
    transform: scale(1.02);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .contact-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-item strong {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
  }

  .contact-item a,
  .contact-item span {
    font-size: 1rem;
    color: var(--color-text);
  }

  .form-success {
    text-align: center;
    padding: 3rem 1rem;
  }

  .success-icon {
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .success-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .success-text {
    font-size: 1rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const success = document.getElementById('formSuccess');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = 'Enviando...';
    btn.disabled = true;

    try {
      const data = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        form.style.display = 'none';
        success.hidden = false;
      } else {
        alert('Ocurrió un error al enviar el mensaje. Por favor, intenta de nuevo.');
      }
    } catch {
      alert('Error de conexión. Por favor, verifica tu internet e intenta de nuevo.');
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
    }
  });
</script>
